<?xml version="1.0" encoding="UTF-8"?>
<mxfile host="app.diagrams.net" modified="2026-03-29T00:00:00.000Z" agent="HyperTool" version="21.0.0">
  <diagram name="Database Schema" id="database-schema">
    <mxGraphModel dx="1422" dy="762" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1600" pageHeight="1000" math="0" shadow="0">
      <root>
        <mxCell id="0"/>
        <mxCell id="1" parent="0"/>

        <!-- Title -->
        <mxCell id="title" value="&lt;b&gt;Figure 4.5 — Database Schema: Firebase Firestore&lt;/b&gt;&lt;br&gt;&lt;i&gt;HyperTool Cloud Data Structure&lt;/i&gt;" style="text;html=1;align=center;verticalAlign=middle;fontSize=16;fontColor=#333333;" vertex="1" parent="1">
          <mxGeometry x="450" y="20" width="500" height="40" as="geometry"/>
        </mxCell>

        <!-- ===== FIRESTORE ROOT ===== -->
        <mxCell id="root_db" value="&lt;b&gt;Firebase Firestore&lt;/b&gt;" style="swimlane;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d79b00;startSize=35;fontSize=14;fontStyle=1;horizontal=1;collapsible=0;rounded=1;" vertex="1" parent="1">
          <mxGeometry x="60" y="80" width="1400" height="700" as="geometry"/>
        </mxCell>

        <!-- ===== COLLECTION: users ===== -->
        <mxCell id="col_users" value="&lt;b&gt;Collection: users&lt;/b&gt;" style="swimlane;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;startSize=28;fontSize=12;fontStyle=1;horizontal=1;rounded=1;" vertex="1" parent="root_db">
          <mxGeometry x="30" y="50" width="420" height="580" as="geometry"/>
        </mxCell>

        <mxCell id="doc_uid" value="&lt;b&gt;Document: {uid}&lt;/b&gt;&lt;br&gt;(Firebase Auth UID)" style="swimlane;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#6c8ebf;startSize=25;fontSize=11;fontStyle=1;horizontal=1;rounded=1;" vertex="1" parent="col_users">
          <mxGeometry x="20" y="40" width="380" height="500" as="geometry"/>
        </mxCell>

        <!-- Sub-collection: vault -->
        <mxCell id="sub_vault" value="&lt;b&gt;Sub-collection: vault&lt;/b&gt;" style="swimlane;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;startSize=25;fontSize=11;fontStyle=1;horizontal=1;rounded=1;" vertex="1" parent="doc_uid">
          <mxGeometry x="15" y="40" width="350" height="200" as="geometry"/>
        </mxCell>

        <mxCell id="vault_fields" value="&lt;div style=&quot;text-align:left;padding:8px;font-size:10px;line-height:1.6&quot;&gt;&lt;b&gt;Document: {credentialId}&lt;/b&gt;&lt;hr&gt;&lt;b&gt;type&lt;/b&gt; : String &lt;i&gt;(login | card)&lt;/i&gt;&lt;br&gt;&lt;b&gt;name&lt;/b&gt; : String&lt;br&gt;&lt;b&gt;username&lt;/b&gt; : String&lt;br&gt;&lt;b&gt;domain&lt;/b&gt; : String&lt;br&gt;&lt;b&gt;encryptedData&lt;/b&gt; : String &lt;i&gt;(AES-256-GCM)&lt;/i&gt;&lt;br&gt;serviceId : String&lt;br&gt;createdAt : Timestamp&lt;br&gt;updatedAt : Timestamp&lt;/div&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#d6b656;overflow=fill;align=left;" vertex="1" parent="sub_vault">
          <mxGeometry x="15" y="35" width="320" height="150" as="geometry"/>
        </mxCell>

        <!-- Sub-collection: vaultConfig -->
        <mxCell id="sub_vconfig" value="&lt;b&gt;Sub-collection: vaultConfig&lt;/b&gt;" style="swimlane;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;startSize=25;fontSize=11;fontStyle=1;horizontal=1;rounded=1;" vertex="1" parent="doc_uid">
          <mxGeometry x="15" y="255" width="350" height="110" as="geometry"/>
        </mxCell>
        <mxCell id="vconfig_fields" value="&lt;div style=&quot;text-align:left;padding:8px;font-size:10px;line-height:1.6&quot;&gt;&lt;b&gt;Document: main&lt;/b&gt;&lt;hr&gt;&lt;b&gt;encryptedVerifyHash&lt;/b&gt; : String &lt;i&gt;(AES-256-GCM)&lt;/i&gt;&lt;br&gt;createdAt : Timestamp&lt;/div&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#d6b656;overflow=fill;align=left;" vertex="1" parent="sub_vconfig">
          <mxGeometry x="15" y="35" width="320" height="60" as="geometry"/>
        </mxCell>

        <!-- Sub-collection: progress -->
        <mxCell id="sub_progress" value="&lt;b&gt;Sub-collection: progress&lt;/b&gt;" style="swimlane;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;startSize=25;fontSize=11;fontStyle=1;horizontal=1;rounded=1;" vertex="1" parent="doc_uid">
          <mxGeometry x="15" y="380" width="350" height="130" as="geometry"/>
        </mxCell>
        <mxCell id="progress_fields" value="&lt;div style=&quot;text-align:left;padding:8px;font-size:10px;line-height:1.6&quot;&gt;&lt;b&gt;Document: data&lt;/b&gt;&lt;hr&gt;&lt;b&gt;xp&lt;/b&gt; : Number&lt;br&gt;&lt;b&gt;level&lt;/b&gt; : Number&lt;br&gt;totalScore : Number&lt;br&gt;streakDays : Number&lt;br&gt;lastActiveDate : String&lt;br&gt;createdAt : Timestamp&lt;/div&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#82b366;overflow=fill;align=left;" vertex="1" parent="sub_progress">
          <mxGeometry x="15" y="35" width="320" height="80" as="geometry"/>
        </mxCell>

        <!-- ===== COLLECTION: dailyTasks (date-keyed) ===== -->
        <mxCell id="col_tasks" value="&lt;b&gt;Collection: dailyTasks (date-keyed)&lt;/b&gt;" style="swimlane;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;startSize=35;fontSize=12;fontStyle=1;horizontal=1;rounded=1;" vertex="1" parent="root_db">
          <mxGeometry x="480" y="50" width="430" height="350" as="geometry"/>
        </mxCell>

        <mxCell id="doc_date" value="&lt;b&gt;Document: {date}&lt;/b&gt;&lt;br&gt;(e.g., 2026-03-29)" style="swimlane;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#82b366;startSize=25;fontSize=11;fontStyle=1;horizontal=1;rounded=1;" vertex="1" parent="col_tasks">
          <mxGeometry x="15" y="45" width="400" height="280" as="geometry"/>
        </mxCell>

        <mxCell id="tasks_fields" value="&lt;div style=&quot;text-align:left;padding:10px;font-size:10px;line-height:1.7&quot;&gt;&lt;b&gt;date&lt;/b&gt; : String&lt;br&gt;&lt;b&gt;totalScore&lt;/b&gt; : Number&lt;br&gt;maxScore : Number&lt;br&gt;createdAt : Timestamp&lt;hr&gt;&lt;b&gt;tasks[] : Array&lt;/b&gt;&lt;br&gt;Each item:&lt;br&gt;&nbsp;&nbsp;id : String&lt;br&gt;&nbsp;&nbsp;type : String &lt;i&gt;(scan | generate_password | check_password | create_credential | generate_encryption)&lt;/i&gt;&lt;br&gt;&nbsp;&nbsp;description : String&lt;br&gt;&nbsp;&nbsp;target : Number&lt;br&gt;&nbsp;&nbsp;current : Number&lt;br&gt;&nbsp;&nbsp;points : Number&lt;br&gt;&nbsp;&nbsp;completed : Boolean&lt;/div&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#82b366;overflow=fill;align=left;" vertex="1" parent="doc_date">
          <mxGeometry x="15" y="35" width="370" height="230" as="geometry"/>
        </mxCell>

        <!-- ===== COLLECTION: scanHistory (optional) ===== -->
        <mxCell id="col_scan" value="&lt;b&gt;Collection: scanHistory (optional)&lt;/b&gt;" style="swimlane;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;startSize=35;fontSize=12;fontStyle=1;horizontal=1;rounded=1;" vertex="1" parent="root_db">
          <mxGeometry x="480" y="420" width="430" height="230" as="geometry"/>
        </mxCell>

        <mxCell id="scan_fields" value="&lt;div style=&quot;text-align:left;padding:10px;font-size:10px;line-height:1.7&quot;&gt;&lt;b&gt;Document: {scanId}&lt;/b&gt;&lt;hr&gt;&lt;b&gt;target&lt;/b&gt; : String&lt;br&gt;&lt;b&gt;scanType&lt;/b&gt; : String &lt;i&gt;(url | file)&lt;/i&gt;&lt;br&gt;status : String&lt;br&gt;reputation : Number&lt;br&gt;maliciousCount : Number&lt;br&gt;suspiciousCount : Number&lt;br&gt;scanDate : Timestamp&lt;br&gt;userId : String&lt;/div&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#9673a6;overflow=fill;align=left;" vertex="1" parent="col_scan">
          <mxGeometry x="15" y="40" width="400" height="170" as="geometry"/>
        </mxCell>

        <!-- ===== PATH LEGEND ===== -->
        <mxCell id="legend" value="&lt;b&gt;Firestore Paths&lt;/b&gt;" style="swimlane;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#cccccc;startSize=28;fontSize=12;fontStyle=1;horizontal=1;rounded=1;" vertex="1" parent="root_db">
          <mxGeometry x="940" y="50" width="430" height="300" as="geometry"/>
        </mxCell>

        <mxCell id="paths" value="&lt;div style=&quot;text-align:left;padding:10px;font-size:10px;line-height:1.8&quot;&gt;&lt;b&gt;Collection Paths:&lt;/b&gt;&lt;br&gt;&lt;code&gt;users/{uid}&lt;/code&gt; — User profile (Firebase Auth)&lt;br&gt;&lt;code&gt;users/{uid}/vault/{credentialId}&lt;/code&gt; — Encrypted credentials&lt;br&gt;&lt;code&gt;users/{uid}/vaultConfig/main&lt;/code&gt; — Master password verification&lt;br&gt;&lt;code&gt;users/{uid}/progress/data&lt;/code&gt; — XP, level, streak&lt;br&gt;&lt;code&gt;users/{uid}/dailyTasks/{date}&lt;/code&gt; — Daily task state&lt;hr&gt;&lt;b&gt;Security Rules:&lt;/b&gt;&lt;br&gt;All collections require authentication.&lt;br&gt;Users can only access their own data.&lt;br&gt;Encrypted data never stored in plaintext.&lt;hr&gt;&lt;b&gt;Notes:&lt;/b&gt;&lt;br&gt;• Credential data is encrypted client-side via Rust AES-256-GCM before storage&lt;br&gt;• Daily tasks are keyed by date (YYYY-MM-DD)&lt;br&gt;• Progress is a single document per user&lt;br&gt;• VaultConfig stores encrypted verification string for master password check&lt;/div&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#cccccc;overflow=fill;align=left;" vertex="1" parent="legend">
          <mxGeometry x="15" y="35" width="400" height="250" as="geometry"/>
        </mxCell>

      </root>
    </mxGraphModel>
  </diagram>
</mxfile>
